#!/bin/sh
# =============================================================================
# AIMS OS — live-build configuration entry point
# =============================================================================
# This script is executed by `lb config`. live-build looks for it at
# config/auto/config relative to its working directory; ours is checked
# in at build/config/auto/config (the host-mounted /build/build/config/
# inside the builder container).
#
# Keeping the configuration in this script rather than letting `lb config`
# write/edit dotfiles under config/ is the recommended pattern — it makes
# every ISO build fully reproducible from version control.
#
# Architecture is detected from the container's own dpkg architecture, so
# the same script Just Works for the amd64 builder and the arm64 builder.
# =============================================================================

set -e

ARCH="$(dpkg --print-architecture)"

case "${ARCH}" in
    amd64)
        LINUX_FLAVOURS="amd64"
        BOOTLOADER="grub-efi"
        ;;
    arm64)
        LINUX_FLAVOURS="arm64"
        BOOTLOADER="grub-efi"
        ;;
    *)
        echo "auto/config: unsupported host architecture '${ARCH}'" >&2
        exit 1
        ;;
esac

# -----------------------------------------------------------------------------
# lb config invocation
# -----------------------------------------------------------------------------
#
#   --mode debian
#       Build a Debian (vs Ubuntu) live system.
#
#   --distribution trixie
#       Pin to Debian 13 (released 2025-08-09; current stable). We do
#       not auto-track "stable" — pinning by codename means a future
#       release of Debian doesn't silently change AIMS OS under us.
#       Bookworm v1.0 lives on the main branch as a fallback.
#
#   --debian-installer live
#   --debian-installer-distribution trixie
#       Embed a live-style installer in the ISO. Calamares itself is
#       pulled in via the package lists (config/package-lists/).
#
#   --architectures
#       Built ISO architecture, taken from the container's own arch.
#
#   --binary-images iso-hybrid
#       Produces a single .iso that is BIOS- and UEFI-bootable and that
#       can also be dd'd directly to a USB stick. The right choice for
#       a distro that ships on USB sticks.
#
#   --linux-flavours
#       Which kernel meta-package to install (linux-image-amd64 or
#       linux-image-arm64). Names changed between releases; "amd64"
#       and "arm64" are the canonical Bookworm flavours.
#
#   --archive-areas
#       Debian sections to enable. We turn on EVERYTHING:
#         main             — the free packages
#         contrib          — free packages that depend on non-free ones
#         non-free         — proprietary userspace (e.g. Steam, some fonts)
#         non-free-firmware — Wi-Fi / GPU blobs split out in Bookworm
#       This is required for the ISO to work on real-world hardware in
#       Senegalese labs, where Wi-Fi and dedicated GPUs are common.
#
#   --bootappend-live
#       Kernel cmdline appended in the live session. Sets locale,
#       keyboard, timezone, default live username and hostname.
#
#   --iso-{application,publisher,volume}
#       Cosmetic strings written into the ISO9660 header — visible
#       in `file <iso>` output and on the boot media's label.
#
#   --memtest none
#       Skip memtest in the boot menu (legacy x86 thing, not useful on
#       arm64 and adds clutter on amd64).
#
#   --firmware-{binary,chroot} true
#       Pull non-free firmware into BOTH the boot environment and the
#       installed system. Required for Wi-Fi/GPU to work out of the box.
#
#   --apt-recommends true
#       Pull Recommends as if they were Depends. Slightly bigger ISO,
#       but matches what a normal `apt install` would do, so end-user
#       behaviour after install is consistent.
#
#   --updates true / --security true
#       Enable trixie-updates and trixie-security repos in the
#       resulting system (and at build time too). live-build derives
#       the suite name from --distribution, so we don't have to spell
#       it out.
# -----------------------------------------------------------------------------
lb config noauto \
    --mode debian \
    --distribution trixie \
    --distribution-binary trixie \
    --debian-installer live \
    --debian-installer-distribution trixie \
    --architectures "${ARCH}" \
    --linux-flavours "${LINUX_FLAVOURS}" \
    --binary-images iso-hybrid \
    --bootloaders "${BOOTLOADER}" \
    --archive-areas "main contrib non-free non-free-firmware" \
    --debian-installer-gui false \
    --iso-application "AIMS OS" \
    --iso-publisher "AIMS Senegal IT <hakim@aims-senegal.org>" \
    --iso-volume "AIMS OS ${ARCH}" \
    --memtest none \
    --firmware-binary true \
    --firmware-chroot true \
    --apt-recommends true \
    --apt-secure true \
    --updates true \
    --security true \
    --backports false \
    --bootappend-live "boot=live components splash quiet console=tty0 plymouth.use-simpledrm=1 locales=fr_FR.UTF-8 keyboard-layouts=fr timezone=Africa/Dakar username=aims user-fullname=AIMS hostname=aims-os" \
    "${@}"
