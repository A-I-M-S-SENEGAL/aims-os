#!/bin/sh
# =============================================================================
# AIMS OS — hook 0097: Cursor (AI code editor)
# =============================================================================
# Cursor is an AI-augmented VS Code fork (proprietary, free tier with
# 2000 AI completions / month). We ship it alongside VSCodium so the
# AIMS Web/Android Dev and Generative AI courses can demo modern
# AI-assisted coding workflows without bandwidth-burning a manual
# download. Students who don't want the AI features can stick with
# VSCodium.
#
# Cursor is not in Debian (proprietary, requires accepting a EULA),
# so we fetch the official .deb directly. The download URL pattern is:
#   https://api2.cursor.sh/updates/download/golden/linux-${arch}-deb/cursor/3.5
# which 302s to the current 3.5.x build on downloads.cursor.com. We pin
# the major-minor (`3.5`) and bump it consciously when we cut a new ISO.
#
# After install, Cursor's own postinst adds the cursor.com apt repo
# (with its GPG key) so subsequent `apt-get upgrade` keeps it current.
# =============================================================================
set -e

BANNER="[aims-os/hook/cursor]"
CURSOR_CHANNEL=3.5
arch=$(dpkg --print-architecture)

case "${arch}" in
    arm64|amd64) ;;
    *)
        echo "${BANNER} arch ${arch} unsupported by Cursor — skipping." >&2
        exit 0
        ;;
esac

echo "${BANNER} downloading Cursor ${CURSOR_CHANNEL} for linux-${arch}..."

URL="https://api2.cursor.sh/updates/download/golden/linux-${arch}-deb/cursor/${CURSOR_CHANNEL}"
DEB=/tmp/cursor.deb

curl -fL --retry 5 --retry-delay 5 --retry-all-errors "${URL}" -o "${DEB}"

# apt-get install handles dependencies that a raw `dpkg -i` would
# leave broken (Cursor pulls libnss3, libgbm1, libasound2t64 etc.).
DEBIAN_FRONTEND=noninteractive apt-get install -y "${DEB}"

rm -f "${DEB}"

echo "${BANNER} Cursor ${CURSOR_CHANNEL} installed."
