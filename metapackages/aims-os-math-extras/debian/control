# --- Python — niche scientific extras --------------------------------
# python3-mpi4py — MPI for Python. AIMS HPC modules (parallel linear
#     algebra, Cooperative Numerical Methods).
# python3-biopython — bioinformatics; AIMS Biological Modelling.
# python3-skimage — scikit-image; general image processing.
# python3-igraph — graph theory (faster than networkx for big graphs).
# python3-rpy2 — call R from Python.
# python3-tables — PyTables, HDF5 dataset wrapper with query syntax.
# python3-pygments — syntax highlighting library.
# python3-reportlab — programmatic PDF generation.
 python3-mpi4py,
 python3-biopython,
 python3-skimage,
 python3-igraph,
 python3-rpy2,
 python3-tables,
 python3-pygments,
 python3-reportlab,
# --- Symbolic + numerical computing -----------------------------------
 maxima,
 maxima-doc,
 wxmaxima,
 octave,
 octave-doc,
 octave-symbolic,
 octave-statistics,
 octave-optim,
 octave-control,
 octave-signal,
# --- R full data-science stack ----------------------------------------
 r-recommended,
 r-cran-tidyverse,
 r-cran-ggplot2,
 r-cran-dplyr,
 r-cran-knitr,
 r-cran-rmarkdown,
# --- TeX Live full multilingual ---------------------------------------
# texlive-lang-other absorbs the formerly separate language packs in
# Trixie and is the closest match for African-language need (Wolof,
# Swahili, Amharic, Hausa, Twi hyphenation).
 texlive-lang-english,
 texlive-lang-other,
 texlive-lang-arabic,
